<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Rememory.Views.Settings.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Rememory.Views.Settings"
      xmlns:tk="using:CommunityToolkit.WinUI"
      xmlns:tkcontrols="using:CommunityToolkit.WinUI.Controls">
    <ScrollViewer Padding="56,20,56,5">
        <StackPanel Padding="0,0,0,28">
            <tkcontrols:SettingsExpander Header="{x:Bind AppName}"
                                         Description="{x:Bind AppDeveloper}"
                                         HeaderIcon="{tk:BitmapIcon Source=ms-appx:///Assets/AppList.targetsize-20.png}"
                                         IsExpanded="True">
                <TextBlock Text="{x:Bind AppVersion}"
                           IsTextSelectionEnabled="True"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <tkcontrols:SettingsExpander.Items>
                    <tkcontrols:SettingsCard ContentAlignment="Left">
                        <StackPanel Orientation="Vertical">
                            <HyperlinkButton NavigateUri="{x:Bind GithubLink}"
                                             Content="GitHub" />

                            <HyperlinkButton x:Uid="/Settings/About_WriteReviewHyperlink"
                                             Loaded="ReviewButton_Loaded"
                                             Click="ReviewButton_Click" />
                        </StackPanel>
                    </tkcontrols:SettingsCard>
                </tkcontrols:SettingsExpander.Items>
            </tkcontrols:SettingsExpander>
        </StackPanel>
    </ScrollViewer>
</Page>
